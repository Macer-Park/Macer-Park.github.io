---
import { SITE_TITLE, NAV } from '../consts';

type Lang = 'en' | 'ko' | 'ja';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const items = NAV[lang];

const homeHrefMap: Record<Lang, string> = { en: '/', ko: '/ko/', ja: '/ja/' };
const homeHref = homeHrefMap[lang];

const langLabel: Record<Lang, string> = { en: 'English', ko: '한국어', ja: '日本語' };
const others: Lang[] = (['en', 'ko', 'ja'] as Lang[]).filter((l) => l !== lang);
---

<header class="border-b" style="border-color: var(--border);">
  <div class="container-wide flex items-center justify-between py-5">
    <a href={homeHref} class="text-base font-semibold tracking-tight" style="border-bottom: none;">
      {SITE_TITLE}
    </a>
    <nav class="flex items-center gap-6 text-sm" style="color: var(--fg-soft);">
      {items.map((item) => <a href={item.href}>{item.label}</a>)}
      <span class="flex items-center gap-3" aria-label="Language switch">
        {others.map((l, idx) => (
          <>
            {idx > 0 && <span aria-hidden="true">·</span>}
            <a href={homeHrefMap[l]}>{langLabel[l]}</a>
          </>
        ))}
      </span>
    </nav>
  </div>
</header>
