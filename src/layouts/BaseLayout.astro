---
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Lang = 'en' | 'ko' | 'ja';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  pathname?: string;
}

const { title, description, lang = 'en', pathname = '/' } = Astro.props;

const baseTitle = `${SITE_TITLE} · ${AUTHOR.role}`;
const fullTitle = title ? `${title} — ${SITE_TITLE}` : baseTitle;
const desc = description ?? SITE_DESCRIPTION;
const canonical = new URL(pathname, SITE_URL).toString();

const basePath = pathname.replace(/^\/(ko|ja)(?=\/|$)/, '') || '/';

const localizePath = (target: Lang) => {
  if (target === 'en') return basePath;
  return basePath === '/' ? `/${target}/` : `/${target}${basePath}`;
};

const alternateLocales: Lang[] = (['en', 'ko', 'ja'] as Lang[]).filter((l) => l !== lang);

const ogLocaleMap: Record<Lang, string> = {
  en: 'en_US',
  ko: 'ko_KR',
  ja: 'ja_JP',
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR.name,
  alternateName: AUTHOR.koreanName,
  jobTitle: AUTHOR.role,
  worksFor: { '@type': 'Organization', name: AUTHOR.company },
  address: { '@type': 'PostalAddress', addressLocality: 'Seoul', addressCountry: 'KR' },
  email: AUTHOR.email,
  url: SITE_URL,
  sameAs: [AUTHOR.linkedin, AUTHOR.github],
  knowsLanguage: ['ko', 'en', 'ja'],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    {alternateLocales.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(localizePath(l), SITE_URL).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', SITE_URL).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocaleMap[lang]} />
    <meta property="og:image" content={new URL('/og.svg', SITE_URL).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={new URL('/og.svg', SITE_URL).toString()} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
