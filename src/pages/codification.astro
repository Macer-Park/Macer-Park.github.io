---
import BaseLayout from '../layouts/BaseLayout.astro';

const essays = [
  {
    n: 3,
    href: '/codification-3',
    title: 'Verifying the verification — after the stamp of passing',
    date: '2026-05-07',
    period: 'April–May 2026',
    minutes: 2,
    excerpt:
      'Two inflection points on verifying the codified verification itself — passing stamps that are not verification, and narrowing your own tool with your own hand.',
  },
  {
    n: 2,
    href: '/codification-2',
    title: 'Verification at the boundary — everything that leaves the system',
    date: '2026-05-06',
    period: 'April–May 2026',
    minutes: 2,
    excerpt:
      'Two inflection points on what it means to verify everything that leaves the system — merchant replies and AI-cited sources.',
  },
  {
    n: 1,
    href: '/codification-1',
    title: 'How I codify mistakes',
    date: '2026-05-06',
    period: 'April 2026',
    minutes: 3,
    excerpt:
      'A retrospective on four inflection points from a single month — crisis, system critique, expansion, and prevention.',
  },
];
---

<BaseLayout
  lang="en"
  title="Codification — retrospective essays"
  description="A running series of retrospective essays on building sanctuary."
  pathname="/codification"
>
  <article class="container-prose pt-20 pb-16">
    <header class="mb-12">
      <div class="text-xs uppercase tracking-widest mb-3" style="color: var(--fg-soft);">
        Series · last updated 2026-05-07
      </div>
      <h1 class="text-3xl sm:text-4xl font-semibold mb-4" style="line-height: 1.2;">
        Codification
      </h1>
      <p class="text-base" style="color: var(--fg-soft);">
        A running set of retrospective essays — what I learned while building sanctuary, and how
        each lesson became code. Newest first.
      </p>
    </header>

    <ul class="space-y-8">
      {
        essays.map((e) => (
          <li>
            <a
              href={e.href}
              class="block card"
              style="display: block;"
            >
              <div
                class="text-xs uppercase tracking-widest mb-2"
                style="color: var(--fg-soft);"
              >
                Essay #{e.n} · {e.period} · ~{e.minutes} min read
              </div>
              <h2 class="text-xl font-semibold mb-2" style="line-height: 1.3;">
                {e.title}
              </h2>
              <p class="text-sm" style="color: var(--fg-soft);">
                {e.excerpt}
              </p>
              <p class="text-sm mt-3">Read →</p>
            </a>
          </li>
        ))
      }
    </ul>

    <footer class="border-t mt-16 pt-6 text-sm" style="border-color: var(--border); color: var(--fg-soft);">
      Korean: <a href="/ko/codification">한국어 목록</a>
    </footer>
  </article>
</BaseLayout>
