---
import BaseLayout from '../../layouts/BaseLayout.astro';

const essays = [
  {
    n: 3,
    href: '/ja/codification-3',
    title: '検証の検証 — 通過印の後の自己反省',
    date: '2026-05-07',
    period: '2026年4–5月',
    chars: 750,
    excerpt:
      '体系化した検証自体を再び検証する回顧 — 通過印は検証の終わりではないという発見、そして自分のツールを自分の手で狭める layer。',
  },
  {
    n: 2,
    href: '/ja/codification-2',
    title: '境界での検証 — 外部に触れるすべてのもの',
    date: '2026-05-06',
    period: '2026年4–5月',
    chars: 700,
    excerpt:
      '外部に触れるすべてのものの1次出典と次のアクション — マーチャント返信と AI 引用出典に対する二つの転換点。',
  },
  {
    n: 1,
    href: '/ja/codification-1',
    title: '一ヶ月の体系化 — sanctuary が教えてくれた4つのこと',
    date: '2026-05-06',
    period: '2026年4月',
    chars: 1500,
    excerpt:
      '一ヶ月間 sanctuary を作りながら向き合った転換点4つの回顧 — 危機、体系化、拡張、再発防止。',
  },
];
---

<BaseLayout
  lang="ja"
  title="体系化 — 回顧録シリーズ"
  description="sanctuary を作りながら書いた回顧録シリーズ。"
  pathname="/ja/codification"
>
  <article class="container-prose pt-20 pb-16">
    <header class="mb-12">
      <div class="text-xs uppercase tracking-widest mb-3" style="color: var(--fg-soft);">
        シリーズ · 最終更新 2026-05-12
      </div>
      <h1 class="text-3xl sm:text-4xl font-semibold mb-4" style="line-height: 1.2;">
        体系化
      </h1>
      <p class="text-base" style="color: var(--fg-soft);">
        sanctuary を作りながら学んだこと、そして各教訓がどうコードになったかについての
        回顧録シリーズ。最新の記事から。
      </p>
    </header>

    <ul class="space-y-8">
      {
        essays.map((e) => (
          <li>
            <a
              href={e.href}
              class="block card"
              style="display: block;"
            >
              <div
                class="text-xs uppercase tracking-widest mb-2"
                style="color: var(--fg-soft);"
              >
                第{e.n}編 · {e.period} · 約 {e.chars.toLocaleString()}字
              </div>
              <h2 class="text-xl font-semibold mb-2" style="line-height: 1.3;">
                {e.title}
              </h2>
              <p class="text-sm" style="color: var(--fg-soft);">
                {e.excerpt}
              </p>
              <p class="text-sm mt-3">読む →</p>
            </a>
          </li>
        ))
      }
    </ul>

    <footer class="border-t mt-16 pt-6 text-sm" style="border-color: var(--border); color: var(--fg-soft);">
      English: <a href="/codification">essay index</a> · 한국어: <a href="/ko/codification">코드화</a>
    </footer>
  </article>
</BaseLayout>
