---
import BaseLayout from '../../layouts/BaseLayout.astro';

const essays = [
  {
    n: 2,
    href: '/ko/codification-2',
    title: '경계에서의 검증 — 외부에 닿는 모든 것',
    date: '2026-05-06',
    period: '2026년 4–5월',
    chars: 700,
    excerpt:
      '외부에 닿는 모든 것의 1차 출처와 다음 액션 — 머천트 회신과 AI 인용 출처에 대한 두 변곡점.',
  },
  {
    n: 1,
    href: '/ko/codification-1',
    title: '한 달의 코드화 — sanctuary가 가르쳐 준 네 가지',
    date: '2026-05-06',
    period: '2026년 4월',
    chars: 1500,
    excerpt:
      '한 달간 sanctuary를 만들면서 마주한 변곡점 4개의 회고 — 위기, 시스템화, 확장, 재발 방지.',
  },
];
---

<BaseLayout
  lang="ko"
  title="코드화 — 회고 시리즈"
  description="sanctuary를 만들며 쓴 회고 시리즈."
  pathname="/ko/codification"
>
  <article class="container-prose pt-20 pb-16">
    <header class="mb-12">
      <div class="text-xs uppercase tracking-widest mb-3" style="color: var(--fg-soft);">
        시리즈 · 마지막 갱신 2026-05-06
      </div>
      <h1 class="text-3xl sm:text-4xl font-semibold mb-4" style="line-height: 1.2;">
        코드화
      </h1>
      <p class="text-base" style="color: var(--fg-soft);">
        sanctuary를 만들면서 배운 것, 그리고 각 교훈이 어떻게 코드가 되었는지에 대한 회고
        시리즈. 최신 글부터.
      </p>
    </header>

    <ul class="space-y-8">
      {
        essays.map((e) => (
          <li>
            <a
              href={e.href}
              class="block card"
              style="display: block;"
            >
              <div
                class="text-xs uppercase tracking-widest mb-2"
                style="color: var(--fg-soft);"
              >
                {e.n}편 · {e.period} · 약 {e.chars.toLocaleString()}자
              </div>
              <h2 class="text-xl font-semibold mb-2" style="line-height: 1.3;">
                {e.title}
              </h2>
              <p class="text-sm" style="color: var(--fg-soft);">
                {e.excerpt}
              </p>
              <p class="text-sm mt-3">읽기 →</p>
            </a>
          </li>
        ))
      }
    </ul>

    <footer class="border-t mt-16 pt-6 text-sm" style="border-color: var(--border); color: var(--fg-soft);">
      English: <a href="/codification">essay index</a>
    </footer>
  </article>
</BaseLayout>
